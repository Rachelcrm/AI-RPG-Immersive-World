DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,testserver
DJANGO_TIME_ZONE=America/New_York

# AWS RDS PostgreSQL (or local Postgres)
# Example: postgresql://postgres:postgres@localhost:5432/rpg_db
DATABASE_URL=sqlite:///db.sqlite3

# MongoDB Atlas
# Example: mongodb+srv://user:password@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=rpg_game

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
RPG_OUTPUT_LANGUAGE=English
TRADE_TAX_RATE=0.05
